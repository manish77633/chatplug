# Server
NODE_ENV=development
PORT=5000
CLIENT_ORIGIN=http://localhost:5173

# MongoDB
MONGO_URI=


# JWT
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRES_IN=7d

# OpenAI
